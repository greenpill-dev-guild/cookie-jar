{
  "version": 2,
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --ignore-scripts",
  "outputDirectory": ".next",
  "rootDirectory": "client",
  "framework": "nextjs",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet ./client",
  "env": {
    "SKIP_CONTRACTS": "true",
    "NODE_ENV": "production"
  }
}
