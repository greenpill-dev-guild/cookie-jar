## Code Quality & Linting Standards

### ESLint Rules (Enforced as Errors)
All new code must pass ESLint with these rules as **errors**:

```typescript
// ❌ no-unused-vars - Remove or prefix with _
const unusedVar = 123; // ERROR

// ✅ Fix: Remove or prefix
const _unusedVar = 123; // OK (indicates intentionally unused)

// ❌ no-console - Use logger instead
console.log('Debug info'); // ERROR

// ✅ Fix: Use logger
import { log } from '@/lib/app/logger';
log.info('Debug info', { context }); // OK

// ❌ react/no-unescaped-entities - Escape quotes
<p>Don't use unescaped quotes</p> // ERROR

// ✅ Fix: Use HTML entities
<p>Don&apos;t use unescaped quotes</p> // OK

// ❌ @next/next/no-img-element - Use Next Image
<img src={url} alt="Photo" /> // ERROR

// ✅ Fix: Use Next.js Image
import Image from 'next/image';
<Image src={url} alt="Photo" width={100} height={100} /> // OK

// ❌ react-hooks/exhaustive-deps - Add all dependencies
useEffect(() => {
  fetchData(userId);
}, []); // ERROR - userId missing

// ✅ Fix: Include all dependencies
useEffect(() => {
  fetchData(userId);
}, [userId, fetchData]); // OK
```

### Unused Variables Best Practices
```typescript
// Function parameters you must keep but don't use:
function Component({ data, _unusedProp }: Props) {
  return <div>{data}</div>;
}

// Destructuring - skip unused values:
const { used, _unused, alsoUsed } = data;

// Or use rest operator:
const { used, ...rest } = data; // rest contains all others

// Loop variables:
array.forEach((_item, index) => {
  console.log(index); // Only using index
});
```

### Image Component Patterns
```tsx
// ✅ GOOD - Next.js Image with proper sizing
import Image from 'next/image';

// Fixed dimensions:
<Image src={url} alt="Icon" width={24} height={24} />

// Responsive with fill:
<div className="relative w-full h-48">
  <Image src={url} alt="Banner" fill sizes="100vw" className="object-cover" />
</div>

// With sizes for optimization:
<Image 
  src={url} 
  alt="Card" 
  fill 
  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
  className="object-cover"
/>

// ❌ BAD - Regular img tag
<img src={url} alt="Photo" className="w-full" />
```

### Pre-Commit Checklist
Before committing, ensure:
- [ ] `pnpm type-check` passes (no TypeScript errors)
- [ ] `pnpm lint` passes (no ESLint errors)
- [ ] No `console.log`, `console.error`, or `console.warn` statements
- [ ] All quotes/apostrophes in JSX are escaped (&apos;, &quot;)
- [ ] All `<img>` tags converted to `<Image />`
- [ ] No unused variables (remove or prefix with `_`)
- [ ] All React hook dependencies included

## Accessibility Requirements

### Semantic HTML
```tsx
// ✅ GOOD - Semantic elements
<nav>
  <ul>
    <li><Link href="/jars">Jars</Link></li>
  </ul>
</nav>

<main>
  <h1>Cookie Jar</h1>
  <article>...</article>
</main>

// ❌ BAD - Div soup
<div className="nav">
  <div className="link">Jars</div>
</div>
```

### ARIA Labels
```tsx
// Interactive elements need labels
<button
  onClick={handleDeposit}
  aria-label="Deposit funds into jar"
  aria-busy={isPending}
>
  <IconDeposit />
</button>

// Form inputs
<input
  type="text"
  id="amount"
  name="amount"
  aria-label="Deposit amount in ETH"
  aria-describedby="amount-help"
  aria-invalid={!!error}
/>
<p id="amount-help">Enter amount to deposit</p>
```

### Keyboard Navigation
```tsx
// Ensure keyboard accessibility
<Dialog onOpenChange={setOpen}>
  <DialogTrigger asChild>
    <Button>Open</Button>
  </DialogTrigger>
  <DialogContent>
    {/* Focus trap automatically handled */}
    <DialogTitle>Confirm</DialogTitle>
    <DialogClose />
  </DialogContent>
</Dialog>
```

## Error Handling

### Error Boundaries
```tsx
// app/error.tsx - Route error boundary
'use client'

export default function Error({ error, reset }: {
  error: Error & { digest?: string }
  reset: () => void
}) {
  return (
    <div className="flex flex-col items-center gap-4 p-8">
      <h2>Something went wrong!</h2>
      <p>{error.message}</p>
      <Button onClick={reset}>Try again</Button>
    </div>
  )
}
```

### Graceful Degradation
```tsx
// Handle loading and error states
if (isLoading) return <LoadingSkeleton />
if (error) return <ErrorState error={error} retry={refetch} />
if (!data) return <EmptyState />

return <SuccessView data={data} />
```

## Testing Requirements

### Component Tests
```typescript
// Focus on user behavior, not implementation
it('allows user to deposit funds', async () => {
  const user = userEvent.setup()
  render(<DepositForm />)
  
  await user.type(screen.getByLabelText(/amount/i), '1.5')
  await user.click(screen.getByRole('button', { name: /deposit/i }))
  
  expect(await screen.findByText(/success/i)).toBeInTheDocument()
})
```

