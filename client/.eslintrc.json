{
	"extends": ["next/core-web-vitals"],
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"rules": {
		"no-unused-vars": "error",
		"no-console": "warn",
		"react/no-unescaped-entities": "error",
		"@next/next/no-img-element": "error",
		"react-hooks/exhaustive-deps": "error",
		"react-hooks/rules-of-hooks": "error"
	}
}
