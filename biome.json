{
  "$schema": "https://biomejs.dev/schemas/2.2.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["client/**/*", "e2e/**/*.ts", "client/**/*.css"],
    "ignores": [
      "client/.next/**",
      "client/node_modules/**",
      "client/dist/**",
      "client/build/**",
      "client/coverage/**",
      "client/.nyc_output/**",
      "**/*.min.js",
      "**/*.min.css"
    ]
  },
  "css": {
    "formatter": {
      "enabled": true,
      "quoteStyle": "double"
    },
    "linter": {
      "enabled": true
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error"
      },
      "style": {
        "useConst": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noUnknownAtRules": "off"
      },
      "a11y": {
        "recommended": true
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "quoteProperties": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "e2e/**/*.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    // Auto-generated files - relaxed rules since they're not manually maintained
    {
      "includes": [
        "**/generated.ts",
        "**/deployments.auto.ts",
        "**/*.auto.ts"
      ],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false,
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "useExhaustiveDependencies": "off",
            "useHookAtTopLevel": "off"
          },
          "style": {
            "useConst": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noArrayIndexKey": "off"
          }
        }
      }
    },
    // Additional auto-generated file patterns
    {
      "includes": [
        "**/generated/**/*",
        "**/*.generated.ts",
        "**/*.generated.tsx",
        "e2e/playwright-report/**"
      ],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      }
    }
  ]
}
