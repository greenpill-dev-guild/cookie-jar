## Testing Standards

### Comprehensive Test Coverage
```solidity
// test/CookieJar.t.sol
contract CookieJarTest is Test {
    CookieJar jar;
    address user = address(0x1);
    
    function setUp() public {
        jar = new CookieJar(address(this));
        vm.deal(user, 100 ether);
    }
    
    // Test success cases
    function test_Deposit_Success() public {
        vm.prank(user);
        jar.deposit{value: 1 ether}();
        assertEq(jar.getBalance(user), 1 ether);
    }
    
    // Test revert conditions
    function test_RevertWhen_InsufficientBalance() public {
        vm.expectRevert(
            abi.encodeWithSelector(
                CookieJar.InsufficientBalance.selector,
                0,
                1 ether
            )
        );
        vm.prank(user);
        jar.withdraw(1 ether);
    }
    
    // Fuzz testing
    function testFuzz_Deposit(uint256 amount) public {
        vm.assume(amount > 0 && amount <= 100 ether);
        vm.deal(user, amount);
        
        vm.prank(user);
        jar.deposit{value: amount}();
        
        assertEq(jar.getBalance(user), amount);
    }
}
```

